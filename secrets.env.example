# Copy this file to ./secrets.env in the root of this repo.
# The real secrets.env file must not be committed.

# --- YouTrack ---------------------------------------------------------------
SF_YOUTRACK_BASE_URL=http://localhost:9700
SF_YOUTRACK_TOKEN=replace-with-local-youtrack-token
SF_YOUTRACK_PROJECTS=

# --- GitHub -----------------------------------------------------------------
SF_GITHUB_TOKEN=replace-with-github-token

# --- Database ---------------------------------------------------------------
SF_DATABASE_URL=postgresql://software_factory:software_factory@localhost:5432/software_factory
SF_DATABASE_SCHEMA=software_factory_dev

# --- AI runtime (optional until the preview/tester/real AI runtime is on) ---
SF_KUBECONFIG=
SF_AI_CREDENTIALS_DIR=
SF_AI_OAUTH_TOKEN=
SF_CODEX_CREDENTIALS_DIR=
SF_COPILOT_CREDENTIALS_DIR=
SF_COPILOT_TOKEN=

# --- Dashboard login --------------------------------------------------------
SF_DASHBOARD_PASSWORD=admin
