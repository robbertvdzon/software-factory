#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

command="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  start)
    # factory-common eerst lokaal installeren: `mvn -f softwarefactory/pom.xml` bouwt alleen die
    # module en zou anders een verouderde (of ontbrekende) factory-common uit ~/.m2 pakken.
    mvn -q -DskipTests -pl factory-common install
    exec mvn -f softwarefactory/pom.xml spring-boot:run "$@"
    ;;
  test)
    exec mvn test "$@"
    ;;
  build-images)
    # Volgorde is belangrijk: assistant:local is FROM agent:local, dus agent eerst.
    docker build -f Dockerfile.agent -t agent:local .
    docker build -f Dockerfile.assistant -t assistant:local .
    ;;
  local-db)
    exec docker compose --env-file secrets.env -f docker/docker-compose.yml up -d postgres
    ;;
  local-db-stop)
    exec docker compose --env-file secrets.env -f docker/docker-compose.yml stop postgres
    ;;
  local-services)
    exec docker compose --env-file secrets.env -f docker/docker-compose.yml up -d --build
    ;;
  local-services-stop)
    exec docker compose --env-file secrets.env -f docker/docker-compose.yml down
    ;;
  *)
    echo "Usage: ./factory [start|test|build-images|local-db|local-db-stop|local-services|local-services-stop] [args...]" >&2
    exit 2
    ;;
esac
