# syntax=docker/dockerfile:1.7

# Runtime-only image for local/SNO testing after `flutter build web`.
# The normal Dockerfile remains self-contained for CI.
FROM nginxinc/nginx-unprivileged:1.27-alpine
USER 0
RUN chgrp -R 0 /etc/nginx /usr/share/nginx/html /var/cache/nginx \
 && chmod -R g+rwX /etc/nginx /usr/share/nginx/html /var/cache/nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY build/web /usr/share/nginx/html
USER 101
EXPOSE 8080
