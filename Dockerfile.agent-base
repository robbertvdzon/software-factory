FROM maven:3.9.10-eclipse-temurin-21 AS build
WORKDIR /build
COPY pom.xml .
COPY softwarefactory ./softwarefactory
COPY agentworker ./agentworker
RUN mvn -q -DskipTests package dependency:copy-dependencies

FROM eclipse-temurin:21-jdk-noble
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates gnupg \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends git jq nodejs gh openssh-client \
    && rm -rf /var/lib/apt/lists/*
ENV NPM_CONFIG_UPDATE_NOTIFIER=false
RUN npm install -g @anthropic-ai/claude-code
RUN useradd -ms /bin/bash runner
ENV HOME=/home/runner \
    NPM_CONFIG_CACHE=/home/runner/.npm
WORKDIR /work
COPY --from=build /build/target/classes /app/classes
COPY --from=build /build/target/dependency /app/libs
COPY softwarefactory/src/main/resources/docs-skeleton /usr/local/share/factory/docs-skeleton
USER runner
ENTRYPOINT ["java", "-cp", "/app/classes:/app/libs/*", "nl.vdzon.softwarefactory.agentworker.cli.AgentCliKt"]
