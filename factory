#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

command="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  start)
    exec mvn -f softwarefactory/pom.xml spring-boot:run "$@"
    ;;
  test)
    exec mvn test "$@"
    ;;
  build-images)
    # Volgorde is belangrijk: assistant:local is FROM agent:local, dus agent eerst.
    docker build -f Dockerfile.agent -t agent:local .
    docker build -f Dockerfile.assistant -t assistant:local .
    ;;
  local-db)
    exec docker compose -f docker/docker-compose.yml up -d postgres
    ;;
  local-db-stop)
    exec docker compose -f docker/docker-compose.yml stop postgres
    ;;
  local-services)
    exec docker compose -f docker/docker-compose.yml up -d
    ;;
  local-services-stop)
    exec docker compose -f docker/docker-compose.yml stop
    ;;
  *)
    echo "Usage: ./factory [start|test|build-images|local-db|local-db-stop|local-services|local-services-stop] [args...]" >&2
    exit 2
    ;;
esac
