# Copy these values to ./secrets.env in the root of this repo.
# The real secrets.env file must not be committed.

SF_JIRA_BASE_URL=https://vdzon.atlassian.net
SF_JIRA_EMAIL=
SF_JIRA_API_KEY=
SF_GITHUB_TOKEN=
SF_DATABASE_URL=
SF_DATABASE_SCHEMA=software_factory

# Optional until the tester/real AI runtime is enabled.
SF_KUBECONFIG=/Users/robbertvdzon/.kube/config
SF_AI_CREDENTIALS_DIR=/Users/robbertvdzon/.claude
SF_AI_OAUTH_TOKEN=

# Optional orchestrator runtime tuning.
SF_ORCHESTRATOR_POLLING_ENABLED=false
SF_POLL_INTERVAL_MS=15000
SF_MAX_PARALLEL_REFINER=1
SF_MAX_PARALLEL_DEVELOPER=2
SF_MAX_PARALLEL_REVIEWER=2
SF_MAX_PARALLEL_TESTER=1
SF_MAX_PARALLEL_TOTAL=4
SF_MAX_DEVELOPER_LOOPBACKS=5
SF_MAX_TRANSIENT_RETRIES=2
SF_AGENT_HARD_TIMEOUT_MINUTES=60
