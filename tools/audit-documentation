#!/usr/bin/env bash
# Deterministische documentatie-audit v1. Geen netwerk nodig; iedere drift is rood.
set -euo pipefail
root="$(cd "$(dirname "$0")/.." && pwd)"
cd "$root"

require() { rg -F --quiet "$2" "$1" || { echo "Ontbrekende documentatiefact: $1 → $2" >&2; exit 1; }; }
for file in README.md runbook.md docs/factory/development.md docs/factory/technical-spec.md docs/technical/modules.md docs/technical/endpoints.md dashboard-frontend/README.md; do
  [[ -f "$file" ]] || { echo "Ontbrekend verplicht document: $file" >&2; exit 1; }
done

require pom.xml '<module>factory-common</module>'
require pom.xml '<module>softwarefactory</module>'
require pom.xml '<module>agentworker</module>'
require pom.xml '<module>dashboard-backend</module>'
require docs/technical/modules.md 'met 12 directe packages'
require docs/technical/modules.md '`bridge`, `config`, `core`, `knowledge`, `merge`'
require docs/technical/overview.md 'V1`–`V15'
require docs/technical/README.md '12 directe Kotlin packages'
require runbook.md 'vaste poll-interval'
require README.md 'Repository verification'
require dashboard-frontend/README.md 'Software Factory Dashboard'

[[ "$(find softwarefactory/src/main/resources/db/migration -name 'V15__*.sql' | wc -l | tr -d ' ')" == 1 ]] || {
  echo 'Flyway V15 ontbreekt.' >&2; exit 1;
}
if rg -n 'pollt adaptief|10 directe packages|V1`–`V14' README.md runbook.md docs/factory docs/technical --glob '!docs/stories/**'; then
  echo 'Verouderde documentatiefact gevonden.' >&2
  exit 1
fi
echo 'documentation-audit/v1: PASS'
