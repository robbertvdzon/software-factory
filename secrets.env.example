# Copy this file to ./secrets.env in the root of this repo.
# The real secrets.env file must not be committed.
#
# These defaults target the local Docker services in ./docker/docker-compose.yml.

SF_YOUTRACK_BASE_URL=http://localhost:9700
# Create this token in local YouTrack after the first-run wizard:
# Profile -> Account Security -> Tokens -> New token.
SF_YOUTRACK_TOKEN=replace-with-local-youtrack-token
# Optional. Leave empty to let the factory discover configured projects.
SF_YOUTRACK_PROJECTS=

# GitHub token with repo access for the target repositories.
SF_GITHUB_TOKEN=replace-with-github-token

# Local Docker Postgres:
SF_DATABASE_URL=postgresql://software_factory:software_factory@localhost:5432/software_factory
SF_DATABASE_SCHEMA=software_factory_dev

# Optional until the preview/tester/real AI runtime is enabled.
SF_KUBECONFIG=
SF_AI_CREDENTIALS_DIR=
SF_AI_OAUTH_TOKEN=

# Optional local dashboard login. Defaults to admin/admin when omitted.
SF_DASHBOARD_USERNAME=admin
SF_DASHBOARD_PASSWORD=admin

# Optional orchestrator runtime tuning.
SF_POLL_INTERVAL_MS=15000
SF_MAX_PARALLEL_REFINER=1
SF_MAX_PARALLEL_DEVELOPER=2
SF_MAX_PARALLEL_REVIEWER=2
SF_MAX_PARALLEL_TESTER=1
SF_MAX_PARALLEL_TOTAL=4
SF_MAX_DEVELOPER_LOOPBACKS=5
SF_MAX_TRANSIENT_RETRIES=2
SF_AGENT_HARD_TIMEOUT_MINUTES=60
