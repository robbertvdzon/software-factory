# Default factory properties (committed to git).
#
#
# --- Orchestrator poll loop -------------------------------------------------
# Delay between orchestrator poll cycles while there is active work.
SF_POLL_INTERVAL_MS=1000
# Delay between poll cycles while the factory is idle (no active stories).
SF_POLL_INTERVAL_IDLE_MS=1000

# --- Parallelism caps -------------------------------------------------------
SF_MAX_PARALLEL_REFINER=1
SF_MAX_PARALLEL_DEVELOPER=2
SF_MAX_PARALLEL_REVIEWER=2
SF_MAX_PARALLEL_TESTER=1
SF_MAX_PARALLEL_TOTAL=4

# --- Loopback / retry behaviour --------------------------------------------
# Max times a single subtask may loop back to the developer before giving up.
SF_MAX_DEVELOPER_LOOPBACKS=5
# Max aantal keren dat een test-bevinding (test-rejected) de hele subtaak-keten
# mag resetten; daarna gaat de story op Error (handmatige triage).
SF_MAX_TEST_CHAIN_RESETS=3
SF_MAX_TRANSIENT_RETRIES=2
SF_AGENT_HARD_TIMEOUT_MINUTES=60
SF_ACTIVE_PHASE_RECOVERY_DELAY_MS=60000

# --- Cost / credits monitoring ---------------------------------------------
SF_COST_MONITOR_INTERVAL_MS=300000
SF_CREDITS_PAUSE_DEFAULT_MINUTES=30

# --- Agent workspace cleanup ------------------------------------------------
SF_AGENT_WORKSPACE_CLEANUP_ENABLED=true
SF_AGENT_WORKSPACE_PRESERVE_ON_FAILURE=false

# --- Dashboard (non-secret) -------------------------------------------------
# Login username. The password lives in secrets.env (it is a secret).
SF_DASHBOARD_USERNAME=admin
SF_DASHBOARD_REMEMBER_DAYS=30
SF_DASHBOARD_COOKIE_SECURE=false
