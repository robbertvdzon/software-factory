FROM maven:3.9.10-eclipse-temurin-21 AS build
WORKDIR /build
# De agentworker hangt sinds de ontdubbeling af van factory-common, dus hier bouwen we een
# mini-reactor (root-pom + factory-common + agentworker) i.p.v. alleen de agentworker-map.
# `-pl agentworker -am` houdt de overige modules (softwarefactory, dashboard-backend) erbuiten.
COPY pom.xml .
COPY docker/prepare-mini-reactor.sh /usr/local/bin/prepare-mini-reactor
COPY factory-contracts/pom.xml factory-contracts/pom.xml
COPY factory-common/pom.xml factory-common/pom.xml
COPY agentworker/pom.xml agentworker/pom.xml
RUN prepare-mini-reactor pom.xml agentworker \
    && mvn -q -pl agentworker -am dependency:go-offline
COPY factory-common/src factory-common/src
COPY factory-contracts/src factory-contracts/src
COPY agentworker/src agentworker/src
RUN mvn -q -DskipTests -pl agentworker -am package dependency:copy-dependencies

FROM eclipse-temurin:21-jdk-noble
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates gnupg \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends git jq nodejs gh openssh-client unzip xz-utils \
    && rm -rf /var/lib/apt/lists/*
ENV NPM_CONFIG_UPDATE_NOTIFIER=false
RUN npm install -g @anthropic-ai/claude-code @openai/codex @github/copilot

# Eén image voor alle agent-rollen. De extra tooling hieronder (browser via
# Playwright/Chromium, cluster-clients oc/kubectl, postgres-client) is alleen
# bruikbaar als de bijbehorende secret wordt gemount. Die secret-injectie is
# per rol geregeld in DockerAgentRuntime (kubeconfig gaat alleen naar de rollen
# die onderzoek/deploy mogen doen). De aanwezigheid van de binaries zelf geeft
# dus geen extra rechten zonder credential.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV SF_PLAYWRIGHT_CHROMIUM_EXECUTABLE=/usr/local/bin/playwright-chromium
RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-client tar \
    && arch="$(dpkg --print-architecture)" \
    && case "$arch" in \
      amd64) oc_arch="amd64" ;; \
      arm64) oc_arch="arm64" ;; \
      *) echo "Unsupported architecture for OpenShift client: $arch" >&2; exit 1 ;; \
    esac \
    && curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/stable/openshift-client-linux-${oc_arch}.tar.gz" -o /tmp/openshift-client.tar.gz \
    && tar -xzf /tmp/openshift-client.tar.gz -C /usr/local/bin oc kubectl \
    && chmod +x /usr/local/bin/oc /usr/local/bin/kubectl \
    && rm -f /tmp/openshift-client.tar.gz \
    && npm install -g playwright \
    && npx playwright install --with-deps chromium \
    && chromium_path="$(find /ms-playwright -path '*/chrome-linux/chrome' -type f | head -n 1)" \
    && test -n "$chromium_path" \
    && ln -sf "$chromium_path" "$SF_PLAYWRIGHT_CHROMIUM_EXECUTABLE" \
    && rm -rf /var/lib/apt/lists/*

# SNO-cluster preview-routes (*.apps.sno.lab.vdzon.com) gebruiken het self-signed
# ingress-operator-certificaat van het cluster (geen publiek vertrouwde CA zoals bij
# vdzonsoftware.nl via Cloudflare). Zonder dit vertrouwt noch de OS-CA-bundel, noch de
# JDK-truststore (die Java's HttpClient in TesterPreviewFlow gebruikt) die routes, en faalt
# elke preview-HTTP-check stil (SSLHandshakeException, weggevangen door runCatching) tot de
# timeout — exact dit gebeurde met SF-1079: de cluster-CA roteerde op 2026-07-14 (cluster-rebuild)
# en bleef 4 dagen onopgemerkt tot de tester-setup van robberts-assistent erop vastliep.
# Root-CA verloopt 2028-07-13; bij rotatie opnieuw exporteren, bv.:
#   openssl s_client -connect <pr-route>:443 -showcerts </dev/null 2>/dev/null \
#     | awk '/BEGIN CERT/,/END CERT/' | openssl x509 -noout -subject -issuer  # check per cert-blok
# en het self-signed blok (subject == issuer) overschrijven naar docker/sno-router-ca.pem.
COPY docker/sno-router-ca.pem /usr/local/share/ca-certificates/sno-router-ca.crt
RUN update-ca-certificates \
    && keytool -importcert -noprompt -trustcacerts -alias sno-router-ca \
       -file /usr/local/share/ca-certificates/sno-router-ca.crt \
       -keystore "$JAVA_HOME/lib/security/cacerts" -storepass changeit

RUN useradd -ms /bin/bash runner
ENV HOME=/home/runner \
    NPM_CONFIG_CACHE=/home/runner/.npm

# Flutter/Dart SDK — agents konden Flutter-wijzigingen (bv. personal-news-feed-by-claude-code's
# frontend) tot nu toe alleen met code-inspectie/grep verifiëren, nooit met een echte
# `flutter test`/`flutter analyze`-run, want er stond geen Flutter-toolchain in deze image.
# Stable-channel, zelfde als wat lokaal gebruikt wordt (Dart 3.9, matcht de frontend's
# `sdk: ^3.9.0`-eis in pubspec.yaml). Eigendom + precache als `runner` zelf, niet als root,
# zodat de cache-bestanden onder $HOME straks door de agent (die als `runner` draait)
# beschrijfbaar zijn.
RUN git clone --depth 1 -b stable https://github.com/flutter/flutter.git /opt/flutter \
    && chown -R runner:runner /opt/flutter
ENV PATH="/opt/flutter/bin:${PATH}"
USER runner
RUN flutter config --no-analytics && flutter precache
USER root

# Maven voor agents om target-projecten (bv. de PNF-backend, een Maven-project) lokaal te
# bouwen/testen. De runtime-image is JDK-only; hergebruik exact dezelfde Maven 3.9.10 uit de
# build-fase i.p.v. apt-get install maven (dat zou een tweede JDK als dependency meetrekken).
COPY --from=build /usr/share/maven /usr/share/maven
RUN ln -sf /usr/share/maven/bin/mvn /usr/local/bin/mvn

WORKDIR /work
COPY --from=build /build/agentworker/target/classes /app/classes
COPY --from=build /build/agentworker/target/dependency /app/libs
# De skeleton leeft nu één keer, in factory-common (voorheen een kopie per module).
COPY factory-common/src/main/resources/docs-skeleton /usr/local/share/factory/docs-skeleton
USER runner
ENTRYPOINT ["java", "-cp", "/app/classes:/app/libs/*", "nl.vdzon.softwarefactory.agentworker.cli.AgentCliKt"]
