# Copy this file to ./secrets.env in the root of this repo.
# The real secrets.env file must not be committed.

# --- Tracker (eigen tracker-tabellen, zie db/migration/V15__tracker_issues.sql) ---
# Projectkeys die gescand worden; leeg = alle project_key's die al in de issues-tabel voorkomen.
SF_TRACKER_PROJECTS=
# Map waar issue-attachments (tester-screenshots) als losse bestanden komen te staan.
SF_TRACKER_ATTACHMENTS_DIR=attachments

# --- GitHub -----------------------------------------------------------------
SF_GITHUB_TOKEN=replace-with-github-token

# --- Database ---------------------------------------------------------------
SF_DATABASE_URL=postgresql://software_factory:software_factory@localhost:5432/software_factory
SF_DATABASE_SCHEMA=software_factory_dev

# --- AI runtime (optional until the preview/tester/real AI runtime is on) ---
SF_KUBECONFIG=
SF_AI_CREDENTIALS_DIR=
SF_AI_OAUTH_TOKEN=
SF_CODEX_CREDENTIALS_DIR=
SF_COPILOT_CREDENTIALS_DIR=
SF_COPILOT_TOKEN=

# --- Dashboard login --------------------------------------------------------
SF_DASHBOARD_PASSWORD=admin

# --- Factory API token -------------------------------------------------------
# Bearer-token voor machine-tot-machine calls op de factory zelf: POST /api/restart
# en de /api/tracker/*-endpoints die de Telegram-assistent's sf-story-tool gebruikt.
SF_FACTORY_API_TOKEN=

# --- Bridge (docs/ontwerp-bridge-dashboard.md) ------------------------------
# Gedeeld token tussen factory en dashboard-backend voor de uitgaande bridge-
# websocket. Leeg op de factory => bridge staat uit; leeg op de backend => elke
# hello wordt geweigerd.
SF_BRIDGE_TOKEN=

# --- Telegram (optional) ----------------------------------------------------
# Beide leeg => uitgeschakeld. Bot-token via @BotFather; chat-id via
# https://api.telegram.org/bot<TOKEN>/getUpdates nadat je de bot een bericht stuurt.
# Bij een vraag/klaar/fout stuurt de factory een melding; reply op een vraag-bericht
# om te antwoorden.
SF_TELEGRAM_BOT_TOKEN=
SF_TELEGRAM_CHAT_ID=
# Optioneel: basis-URL van het dashboard voor klikbare links in meldingen
# (bv. https://factory.example.com). Leeg => geen link in de melding.
SF_DASHBOARD_BASE_URL=
