# Optional cluster-specific copy for deploy/seal-secrets.sh.
# By default seal-secrets.sh reads ../secrets.env from the repository root.
# Copy this file to deploy/secrets-cluster.env only when the cluster values
# must differ from your local root secrets.env.

SF_TRACKER_PROJECTS=
SF_GITHUB_TOKEN=
SF_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
SF_DATABASE_SCHEMA=software_factory
# Bridge-dashboard logt in via Google-SSO (zie SF-794/SF-795): OAuth-web-client-ID
# (audience) + allowlist van toegestane e-mailadressen. SF_DASHBOARD_REMEMBER_SECRET
# ondertekent het sessie-token (verplicht).
SF_GOOGLE_CLIENT_ID=
SF_ALLOWED_EMAILS=robbert@vdzon.com
SF_DASHBOARD_REMEMBER_SECRET=
SF_DASHBOARD_COOKIE_SECURE=true
