#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

command="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  start)
    exec mvn spring-boot:run "$@"
    ;;
  test)
    exec mvn test "$@"
    ;;
  build-images)
    docker build -f Dockerfile.agent-base -t agent-base:local .
    docker build -f Dockerfile.agent-tester -t agent-tester:local .
    ;;
  init-repo)
    mvn -q -DskipTests compile dependency:copy-dependencies
    exec java -cp "target/classes:target/dependency/*" nl.vdzon.softwarefactory.docs.InitRepoCliKt "$@"
    ;;
  *)
    echo "Usage: ./factory [start|test|build-images|init-repo] [args...]" >&2
    exit 2
    ;;
esac
